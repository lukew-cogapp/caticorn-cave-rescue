---
import Layout from "../layouts/Layout.astro";
import { EN } from "../game/strings/en";
---

<Layout title={EN.title} description={EN.metaDescription}>
	<main class="mx-auto max-w-6xl px-6 py-8">
		<header class="flex flex-col items-center text-center">
			<canvas
				id="title-sprite"
				width="64"
				height="64"
				class="h-12 w-12"
				aria-hidden="true"></canvas>
			<h1
				class="mt-1 text-3xl font-extrabold tracking-tight text-stone-900 sm:text-4xl"
			>
				{EN.title}
			</h1>
			<p class="mt-2 text-stone-600">{EN.tagline}</p>
		</header>

		<!-- Game canvas (HUD is rendered inside the canvas) -->
		<div
			id="game-stage"
			tabindex="-1"
			class="relative mx-auto mt-4 aspect-video w-full overflow-hidden rounded-2xl border-4 border-stone-900 shadow-lg focus:outline-none"
			style="max-width: min(100%, calc(80vh * 16 / 9));"
		>
			<canvas id="game-canvas" class="block h-full w-full"></canvas>

			<!-- Start screen: title + character select -->
			<div
				id="start-screen"
				class="absolute inset-0 z-20 flex flex-col items-center justify-center bg-gradient-to-b from-indigo-950/95 to-purple-950/95 px-4 text-center text-amber-50 backdrop-blur-sm"
			>
				<canvas
					id="hero-sprite"
					width="96"
					height="96"
					class="h-20 w-20 drop-shadow-lg"
					aria-hidden="true"></canvas>
				<h2 class="mt-2 text-2xl font-extrabold tracking-tight sm:text-4xl">
					{EN.title}
				</h2>
				<p class="mt-1 text-sm text-indigo-200 sm:text-base">
					{EN.chooseHero}
				</p>

				<div
					id="char-cards"
					class="mt-5 flex flex-wrap items-stretch justify-center gap-4"
				>
					<!-- Cards injected by script (one per CHARACTERS entry). -->
				</div>

				<button
					id="start-btn"
					type="button"
					disabled
					class="mt-6 rounded-full bg-amber-400 px-8 py-3 text-lg font-extrabold text-stone-900 shadow-lg transition enabled:hover:scale-105 enabled:hover:bg-amber-300 disabled:cursor-not-allowed disabled:opacity-40"
				>
					{EN.startButton}
				</button>
				<p class="mt-3 text-xs text-indigo-300">{EN.controlsHint}</p>
			</div>

			<!-- Fullscreen toggle -->
			<button
				id="fullscreen-btn"
				type="button"
				aria-label="Toggle fullscreen"
				class="absolute right-3 top-3 z-10 rounded-lg bg-stone-900/70 px-3 py-1.5 text-sm font-semibold text-amber-50 backdrop-blur transition hover:bg-stone-900"
			>
				{EN.fullscreen}
			</button>

			<!-- Overlay for win/lose -->
			<div
				id="overlay"
				class="absolute inset-0 hidden flex-col items-center justify-center bg-stone-900/80 text-center text-amber-50"
			>
				<h2 id="overlay-title" class="text-3xl font-extrabold"></h2>
				<p id="overlay-sub" class="mt-2 text-stone-300"></p>
				<button
					id="restart-btn"
					class="mt-5 rounded-full bg-amber-400 px-6 py-2 font-bold text-stone-900 transition hover:bg-amber-300"
				>
					{EN.playAgain}
				</button>
			</div>

			<!-- Touch controls: left-thumb move pad + right-thumb jump.
			     Shown only on touch devices (toggled via the `touch` class). -->
			<div
				id="touch-controls"
				class="pointer-events-none absolute inset-x-0 bottom-0 z-30 hidden items-end justify-between p-4 select-none"
			>
				<div class="pointer-events-auto flex gap-3">
					<button
						id="btn-left"
						type="button"
						aria-label={EN.moveLeft}
						class="flex h-16 w-16 items-center justify-center rounded-full bg-stone-900/55 text-2xl font-bold text-amber-50 backdrop-blur active:bg-stone-900/80"
					>‹</button>
					<button
						id="btn-right"
						type="button"
						aria-label={EN.moveRight}
						class="flex h-16 w-16 items-center justify-center rounded-full bg-stone-900/55 text-2xl font-bold text-amber-50 backdrop-blur active:bg-stone-900/80"
					>›</button>
				</div>
				<button
					id="btn-jump"
					type="button"
					aria-label={EN.jump}
					class="pointer-events-auto flex h-20 w-20 items-center justify-center rounded-full bg-amber-400/80 text-sm font-extrabold text-stone-900 backdrop-blur active:bg-amber-300"
				>JUMP</button>
			</div>
		</div>

		<p class="mt-4 text-center text-sm text-stone-500">{EN.controlsFooter}</p>
	</main>
</Layout>

<script>
	import { Application } from "pixi.js";
	import { drawPlayer, type PlayerVariant } from "../game/art";
	import { bootGame, CHARACTERS, type HudState } from "../game/caticorn";
	import { EN } from "../game/strings/en";

	const canvas = document.getElementById("game-canvas") as HTMLCanvasElement;
	const stage = document.getElementById("game-stage") as HTMLDivElement;
	const fsBtn = document.getElementById("fullscreen-btn") as HTMLButtonElement;
	const overlay = document.getElementById("overlay") as HTMLDivElement;
	const overlayTitle = document.getElementById("overlay-title")!;
	const overlaySub = document.getElementById("overlay-sub")!;
	const restartBtn = document.getElementById("restart-btn")!;
	const startScreen = document.getElementById("start-screen") as HTMLDivElement;
	const cardsWrap = document.getElementById("char-cards") as HTMLDivElement;
	const startBtn = document.getElementById("start-btn") as HTMLButtonElement;

	// The level / rescued / lives readouts are drawn inside the canvas (Pixi HUD).
	// This callback only drives the DOM win/lose overlay.
	function renderHud(s: HudState) {
		if (s.status === "playing") {
			overlay.classList.add("hidden");
			overlay.classList.remove("flex");
			return;
		}
		overlay.classList.remove("hidden");
		overlay.classList.add("flex");
		if (s.status === "won") {
			overlayTitle.textContent = EN.wonTitle;
			overlaySub.textContent = EN.wonSub;
		} else {
			overlayTitle.textContent = EN.lostTitle;
			overlaySub.textContent = EN.lostSub(s.rescued);
		}
	}

	const game = await bootGame(canvas, renderHud);

	// Render a drawn caticorn (not an emoji) into a small canvas.
	async function renderSpriteInto(
		c: HTMLCanvasElement,
		variant: PlayerVariant,
		bottomY: number,
	) {
		const a = new Application();
		await a.init({
			canvas: c,
			width: c.width,
			height: c.height,
			backgroundAlpha: 0,
			antialias: true,
		});
		const s = drawPlayer(variant);
		s.x = c.width / 2;
		s.y = bottomY;
		a.stage.addChild(s);
	}
	const titleCanvas = document.getElementById(
		"title-sprite",
	) as HTMLCanvasElement;
	const heroCanvas = document.getElementById("hero-sprite") as HTMLCanvasElement;
	await renderSpriteInto(titleCanvas, "aubrey", 60);
	await renderSpriteInto(heroCanvas, "quinn", 90);

	// Render the game at the stage's actual pixel size so it always fills the
	// box crisply (rather than CSS-upscaling a fixed 800x450 canvas).
	function fitToStage() {
		if (document.fullscreenElement === stage) return; // fullscreen handles itself
		const rect = stage.getBoundingClientRect();
		if (rect.width > 0 && rect.height > 0) {
			game.resize(rect.width, rect.height);
		}
	}
	new ResizeObserver(fitToStage).observe(stage);
	fitToStage();

	// --- Character select ---
	let chosen: PlayerVariant | null = null;
	const cardEls = new Map<PlayerVariant, HTMLButtonElement>();

	for (const c of CHARACTERS) {
		const card = document.createElement("button");
		card.type = "button";
		card.dataset.variant = c.id;
		card.className =
			"group flex w-32 flex-col items-center gap-2 rounded-2xl border-2 border-white/15 bg-white/5 p-4 transition hover:border-white/40 hover:bg-white/10";

		// Live Pixi sprite preview of the character.
		const preview = document.createElement("canvas");
		preview.width = 96;
		preview.height = 96;
		preview.className = "h-24 w-24";
		card.appendChild(preview);

		const name = document.createElement("span");
		name.textContent = c.name;
		name.className = "text-lg font-bold";
		name.style.color = c.color;
		card.appendChild(name);

		card.addEventListener("click", () => select(c.id));
		cardsWrap.appendChild(card);
		cardEls.set(c.id, card);

		// Render the caticorn into the preview canvas with a tiny Pixi app.
		const app = new Application();
		await app.init({
			canvas: preview,
			width: 96,
			height: 96,
			backgroundAlpha: 0,
			antialias: true,
		});
		const sprite = drawPlayer(c.id);
		sprite.x = 48;
		sprite.y = 86; // bottom-centre origin sits near the bottom
		app.stage.addChild(sprite);
	}

	function select(variant: PlayerVariant) {
		chosen = variant;
		startBtn.disabled = false;
		for (const [id, card] of cardEls) {
			const active = id === variant;
			card.classList.toggle("border-amber-400", active);
			card.classList.toggle("bg-white/15", active);
			card.classList.toggle("ring-2", active);
			card.classList.toggle("ring-amber-400", active);
		}
	}

	startBtn.addEventListener("click", () => {
		if (!chosen) return;
		startScreen.classList.add("hidden");
		game.start(chosen);
		stage.focus();
	});

	restartBtn.addEventListener("click", () => game.restart());

	// --- Touch controls ---
	// The engine listens for keyboard events on window, so on-screen buttons
	// just synthesize the matching key down/up. Shown only on touch devices.
	const touchControls = document.getElementById(
		"touch-controls",
	) as HTMLDivElement;
	const isTouch =
		"ontouchstart" in window || navigator.maxTouchPoints > 0;
	if (isTouch) {
		touchControls.classList.remove("hidden");
		touchControls.classList.add("flex");
	}

	function holdButton(id: string, key: string) {
		const btn = document.getElementById(id);
		if (!btn) return;
		const press = (e: Event) => {
			e.preventDefault();
			window.dispatchEvent(new KeyboardEvent("keydown", { key }));
		};
		const release = (e: Event) => {
			e.preventDefault();
			window.dispatchEvent(new KeyboardEvent("keyup", { key }));
		};
		btn.addEventListener("touchstart", press, { passive: false });
		btn.addEventListener("touchend", release, { passive: false });
		btn.addEventListener("touchcancel", release, { passive: false });
		// Mouse fallback (e.g. desktop testing / hybrid devices).
		btn.addEventListener("mousedown", press);
		btn.addEventListener("mouseup", release);
		btn.addEventListener("mouseleave", release);
	}
	holdButton("btn-left", "ArrowLeft");
	holdButton("btn-right", "ArrowRight");
	holdButton("btn-jump", "ArrowUp");

	// --- Fullscreen ---
	function syncFullscreenSize() {
		if (document.fullscreenElement === stage) {
			game.resize(window.innerWidth, window.innerHeight);
		} else {
			fitToStage();
		}
	}

	fsBtn.addEventListener("click", () => {
		if (document.fullscreenElement) {
			document.exitFullscreen();
		} else {
			stage.requestFullscreen().catch(() => {
				/* fullscreen denied/unsupported; ignore */
			});
		}
	});

	document.addEventListener("fullscreenchange", () => {
		const active = document.fullscreenElement === stage;
		fsBtn.textContent = active ? EN.exitFullscreen : EN.fullscreen;
		syncFullscreenSize();
		if (active) stage.focus();
	});
	window.addEventListener("resize", syncFullscreenSize);
</script>

<style>
	/* In fullscreen, fill the screen and centre the canvas. */
	#game-stage:fullscreen {
		display: flex;
		align-items: center;
		justify-content: center;
		background: #1a1124;
		border: none;
		border-radius: 0;
		max-width: none;
		max-height: none;
		width: 100vw;
		height: 100vh;
	}
	#game-stage:fullscreen canvas {
		width: 100vw !important;
		height: 100vh !important;
	}
</style>
