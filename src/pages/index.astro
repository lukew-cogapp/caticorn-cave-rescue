---
import BootSkeleton from "../components/BootSkeleton.astro";
import HudBar from "../components/HudBar.astro";
import RotateHint from "../components/RotateHint.astro";
import StartScreen from "../components/StartScreen.astro";
import TouchControls from "../components/TouchControls.astro";
import WinLoseOverlay from "../components/WinLoseOverlay.astro";
import { EN } from "../game/strings/en";
import Layout from "../layouts/Layout.astro";
---

<Layout title={EN.title} description={EN.metaDescription}>
	<!-- Full-viewport, non-scrolling shell. The in-canvas start screen already
	     shows the title + "choose your hero", so the page needs no header/footer
	     chrome; everything fits the screen with no scroll. -->
	<main
		id="page"
		class="flex h-[100dvh] flex-col items-center justify-center gap-2 overflow-hidden px-4 py-3"
	>
		<HudBar />

		<!-- Game canvas -->
		<div
			id="game-stage"
			tabindex="-1"
			class="relative mx-auto mt-2 aspect-video w-full overflow-hidden rounded-2xl border-4 border-stone-900 shadow-lg focus:outline-none"
			style="max-width: min(100%, calc(80vh * 16 / 9));"
		>
			<canvas id="game-canvas" class="block h-full w-full"></canvas>

			<BootSkeleton />

			<StartScreen />

			<RotateHint />

			<WinLoseOverlay />

			<TouchControls />
		</div>
	</main>

	<!--
		PWA install toast — hidden by default; page.ts reveals it when:
		  - Android/Chrome: `beforeinstallprompt` fires (not yet installed)
		  - iOS Safari: running in browser (not standalone) and not dismissed before

		#install-toast    — the container (shown/hidden by JS)
		#install-btn      — triggers the native Android A2HS prompt
		#install-ios-hint — replaces the button row on iOS with a plain text hint
		#install-dismiss  — hides the toast and writes to localStorage
	-->
	<div
		id="install-toast"
		role="status"
		aria-live="polite"
		class="fixed bottom-4 left-1/2 z-50 hidden -translate-x-1/2 items-center gap-3 rounded-2xl border border-white/20 bg-[#26134f] px-4 py-3 text-sm text-white shadow-xl"
	>
		<!-- Android / Chrome path: native prompt button -->
		<span id="install-android" class="flex items-center gap-3">
			<span class="text-base">📲</span>
			<button
				id="install-btn"
				type="button"
				class="font-semibold text-amber-300 underline-offset-2 hover:underline"
			>
				{EN.installPrompt}
			</button>
			<span class="text-white/40">·</span>
		</span>
		<!-- iOS Safari path: instructional hint, no button -->
		<span id="install-ios" class="hidden items-center gap-2">
			<span class="text-base">📲</span>
			<span>{EN.iosInstallHint}</span>
			<span class="text-white/40">·</span>
		</span>
		<button
			id="install-dismiss"
			type="button"
			aria-label="Dismiss install prompt"
			class="text-white/50 hover:text-white"
		>
			✕
		</button>
	</div>
</Layout>

<script>
	import "../scripts/page.ts";
</script>

<style>
	/* In fullscreen, fill the screen and centre the canvas. */
	#game-stage:fullscreen {
		display: flex;
		align-items: center;
		justify-content: center;
		background: #1a1124;
		border: none;
		border-radius: 0;
		max-width: none;
		max-height: none;
		width: 100vw;
		height: 100vh;
	}
	#game-stage:fullscreen canvas {
		width: 100vw !important;
		height: 100vh !important;
	}

	/* On portrait touch devices (coarse pointer), prompt to rotate. Hidden on
	   desktop and on landscape phones/tablets. */
	@media (orientation: portrait) and (pointer: coarse) {
		#rotate-hint {
			display: flex;
		}
	}

	/* Short landscape (phones held sideways): drop the page header + padding so
	   the game frame fills the viewport and the start screen isn't pushed off
	   the bottom. The in-canvas title already carries the branding. */
	@media (max-height: 520px) and (orientation: landscape) {
		#page {
			padding: 0;
		}
		#page-header {
			display: none;
		}
		#game-stage {
			margin-top: 0;
			max-width: 100vw !important;
			height: 100vh;
			border-radius: 0;
			border-width: 0;
		}
	}
</style>
