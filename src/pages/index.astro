---
import BootSkeleton from "../components/BootSkeleton.astro";
import HudBar from "../components/HudBar.astro";
import RotateHint from "../components/RotateHint.astro";
import StartScreen from "../components/StartScreen.astro";
import TouchControls from "../components/TouchControls.astro";
import WinLoseOverlay from "../components/WinLoseOverlay.astro";
import { EN } from "../game/strings/en";
import Layout from "../layouts/Layout.astro";
---

<Layout title={EN.title} description={EN.metaDescription}>
	<main id="page" class="px-6 py-8">
		<header
			id="page-header"
			class="mx-auto flex max-w-3xl flex-col items-center text-center"
		>
			<canvas
				id="title-sprite"
				width="64"
				height="64"
				class="h-12 w-12"
				aria-hidden="true"></canvas>
			<h1
				class="mt-1 text-3xl font-extrabold tracking-tight text-stone-900 sm:text-4xl"
			>
				{EN.title}
			</h1>
			<p class="mt-2 text-stone-600">{EN.tagline}</p>
		</header>

		<HudBar />

		<!-- Game canvas -->
		<div
			id="game-stage"
			tabindex="-1"
			class="relative mx-auto mt-2 aspect-video w-full overflow-hidden rounded-2xl border-4 border-stone-900 shadow-lg focus:outline-none"
			style="max-width: min(100%, calc(80vh * 16 / 9));"
		>
			<canvas id="game-canvas" class="block h-full w-full"></canvas>

			<BootSkeleton />

			<StartScreen />

			<!-- Fullscreen toggle (bottom-right so it never covers the HUD bar) -->
			<button
				id="fullscreen-btn"
				type="button"
				aria-label="Toggle fullscreen"
				class="absolute bottom-3 right-3 z-10 rounded-lg bg-stone-900/70 px-3 py-1.5 text-sm font-semibold text-amber-50 backdrop-blur transition hover:bg-stone-900"
			>
				{EN.fullscreen}
			</button>

			<RotateHint />

			<WinLoseOverlay />

			<TouchControls />
		</div>

		<p class="mx-auto mt-4 max-w-3xl text-center text-sm text-stone-500">
			{EN.controlsFooter}
		</p>
	</main>
</Layout>

<script>
	import "../scripts/page.ts";
</script>

<style>
	/* In fullscreen, fill the screen and centre the canvas. */
	#game-stage:fullscreen {
		display: flex;
		align-items: center;
		justify-content: center;
		background: #1a1124;
		border: none;
		border-radius: 0;
		max-width: none;
		max-height: none;
		width: 100vw;
		height: 100vh;
	}
	#game-stage:fullscreen canvas {
		width: 100vw !important;
		height: 100vh !important;
	}

	/* On portrait touch devices (coarse pointer), prompt to rotate. Hidden on
	   desktop and on landscape phones/tablets. */
	@media (orientation: portrait) and (pointer: coarse) {
		#rotate-hint {
			display: flex;
		}
	}

	/* Short landscape (phones held sideways): drop the page header + padding so
	   the game frame fills the viewport and the start screen isn't pushed off
	   the bottom. The in-canvas title already carries the branding. */
	@media (max-height: 520px) and (orientation: landscape) {
		#page {
			padding: 0;
		}
		#page-header {
			display: none;
		}
		#game-stage {
			margin-top: 0;
			max-width: 100vw !important;
			height: 100vh;
			border-radius: 0;
			border-width: 0;
		}
	}
</style>
