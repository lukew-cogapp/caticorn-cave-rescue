---
import { EN } from "../game/strings/en";
---

<!-- Overlay for win/lose -->
<div
	id="overlay"
	class="absolute inset-0 hidden flex-col items-center justify-center bg-stone-900/80 text-center text-amber-50"
>
	<h2 id="overlay-title" class="text-3xl font-extrabold"></h2>
	<p id="overlay-sub" class="mt-2 text-stone-300"></p>
	<!-- Flawless-run badge (shown only on a perfect win: all four feats held). -->
	<div
		id="flawless-badge"
		class="mt-4 hidden max-w-md rounded-2xl bg-gradient-to-r from-amber-400/20 via-pink-400/20 to-amber-400/20 px-5 py-3 ring-1 ring-amber-300/40"
	>
		<p
			class="bg-gradient-to-r from-amber-300 via-pink-200 to-amber-300 bg-clip-text text-lg font-extrabold tracking-wide text-transparent"
		>
			{EN.flawlessTitle}
		</p>
		<p class="mt-1 text-sm text-amber-100">{EN.flawlessSub}</p>
	</div>

	<!-- Achievements actually earned this run (each row shown only if held).
	     Hidden as a block when none were earned or it's not a win. -->
	<div
		id="achievements"
		class="mt-4 hidden w-full max-w-xs rounded-2xl bg-white/5 px-5 py-3 text-left ring-1 ring-white/10"
	>
		<p class="mb-2 text-center text-xs font-bold tracking-wide text-amber-200/80">
			{EN.achievementsTitle}
		</p>
		<ul class="space-y-1.5 text-sm font-medium text-amber-50">
			{
				Object.entries(EN.achievements).map(([key, a]) => (
					<li
						data-feat={key}
						class="hidden items-center gap-2.5 data-[earned]:flex"
					>
						<span class="text-base">{a.icon}</span>
						<span>{a.label}</span>
					</li>
				))
			}
		</ul>
	</div>
	<div class="mt-5 flex flex-wrap items-center justify-center gap-3">
		<button
			id="restart-btn"
			class="rounded-full bg-amber-400 px-6 py-2 font-bold text-stone-900 transition hover:bg-amber-300"
		>
			{EN.playAgain}
		</button>
		<button
			id="to-start-btn"
			class="rounded-full bg-white/10 px-6 py-2 font-bold text-amber-50 ring-1 ring-white/20 transition hover:bg-white/20"
		>
			{EN.returnToStart}
		</button>
	</div>
</div>
