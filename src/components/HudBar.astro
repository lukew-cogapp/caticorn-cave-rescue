---
import { EN } from "../game/strings/en";
// HUD score bar: lives ABOVE the playfield so it never overlaps spikes,
// monsters or the player. Hidden until a run starts. Also hosts the fullscreen
// toggle on the right (no longer a floating button over the canvas).
---

<div
	id="hud-bar"
	class="mx-auto mt-4 hidden w-full items-center justify-between gap-3 rounded-xl bg-stone-900/80 px-4 py-2 text-sm font-bold text-amber-100 shadow-md ring-1 ring-white/10 sm:text-base"
	style="max-width: min(100%, calc(80vh * 16 / 9));"
>
	<span id="hud-level" class="truncate"></span>
	<span id="hud-rescued" class="shrink-0 text-pink-200"></span>
	<span class="flex shrink-0 items-center gap-3">
		<span class="flex items-center gap-3 tabular-nums text-amber-200">
			<span id="hud-score"></span>
			<span class="text-white/25" aria-hidden="true">|</span>
			<span id="hud-time" class="inline-flex items-center gap-1"
				><span aria-hidden="true">⏱</span><span id="hud-time-val"></span></span
			>
		</span>
		<button
			id="fullscreen-btn"
			type="button"
			aria-label="Toggle fullscreen"
			class="rounded-lg bg-white/10 px-2.5 py-1 text-xs font-semibold text-amber-50 ring-1 ring-white/15 transition hover:bg-white/20"
		>
			{EN.fullscreen}
		</button>
	</span>
</div>
