---
import { EN } from "../game/strings/en";
---

<!-- Start screen: title + character select -->
<div
	id="start-screen"
	class="absolute inset-0 z-20 flex flex-col items-center justify-center gap-2 overflow-y-auto bg-gradient-to-b from-indigo-950/95 to-purple-950/95 px-4 py-2 text-center text-amber-50 backdrop-blur-sm [@media(max-height:800px)]:gap-1 [@media(max-height:800px)]:py-1"
>
	<canvas
		id="hero-sprite"
		width="96"
		height="96"
		class="hidden h-16 w-16 drop-shadow-lg sm:block [@media(max-height:800px)]:h-10 [@media(max-height:800px)]:w-10"
		aria-hidden="true"></canvas>
	<h2 class="text-xl font-extrabold tracking-tight sm:text-3xl [@media(max-height:800px)]:sm:text-2xl">
		{EN.title}
	</h2>
	<p class="text-xs text-indigo-200 sm:text-sm [@media(max-height:800px)]:sm:text-xs">
		{EN.chooseHero}
	</p>

	<!-- Run summary shown after a game over (hidden otherwise). -->
	<p
		id="run-summary"
		class="hidden rounded-xl bg-amber-400/15 px-4 py-1.5 text-sm font-semibold text-amber-200"
	>
	</p>

	<div
		id="char-cards"
		class="flex flex-wrap items-stretch justify-center gap-2 [@media(max-height:800px)]:gap-1.5"
	>
		<!-- Cards injected by script (one per CHARACTERS entry). -->
	</div>

	<button
		id="start-btn"
		type="button"
		disabled
		class="rounded-full bg-amber-400 px-8 py-2 text-base font-extrabold text-stone-900 shadow-lg transition enabled:hover:scale-105 enabled:hover:bg-amber-300 disabled:cursor-not-allowed disabled:opacity-40 sm:text-lg sm:py-2.5 [@media(max-height:800px)]:py-1.5 [@media(max-height:800px)]:text-sm"
	>
		{EN.startButton}
	</button>
	<p
		class="bg-gradient-to-r from-amber-300 via-pink-300 to-amber-300 bg-clip-text text-base font-extrabold tracking-tight text-transparent sm:text-xl [@media(max-height:800px)]:sm:text-base"
	>
		{EN.instructionsHeadline}
	</p>
	<div
		class="w-full max-w-md rounded-2xl bg-indigo-950/40 px-4 py-3 text-left text-xs font-medium text-indigo-100 ring-1 ring-white/10 sm:px-5 sm:py-4 sm:text-sm [@media(max-height:800px)]:py-2 [@media(max-height:800px)]:sm:py-2.5 [@media(max-height:800px)]:sm:text-xs"
	>
		<ul class="space-y-1 [@media(max-height:800px)]:space-y-0.5">
			{
				EN.instructions.map((line) => (
					<li class="flex items-start gap-2">
						<span class="w-5 shrink-0 text-center leading-5 [@media(max-height:800px)]:leading-4">
							{line.icon}
						</span>
						<span class="leading-5 [@media(max-height:800px)]:leading-4">{line.text}</span>
					</li>
				))
			}
		</ul>
		<p
			class="mt-2 border-t border-white/10 pt-2 text-xs text-indigo-300 [@media(max-height:800px)]:mt-1.5 [@media(max-height:800px)]:pt-1.5"
		>
			{EN.controlsHint}
		</p>
	</div>
</div>
