---
import { EN } from "../game/strings/en";
---

<!-- Start screen: title + character select. Deliberate vertical rhythm: items
     are tight WITHIN a group and separated by larger margins BETWEEN groups
     (header / cards / start button / instructions), rather than one flat gap. -->
<div
	id="start-screen"
	class="absolute inset-0 z-20 flex flex-col items-center justify-center overflow-y-auto bg-gradient-to-b from-indigo-950/95 to-purple-950/95 px-4 py-4 text-center text-amber-50 backdrop-blur-sm [@media(max-height:800px)]:py-2"
>
	<!-- Header group: hero sprite + title + subhead, tightly stacked. -->
	<div class="flex flex-col items-center">
		<canvas
			id="hero-sprite"
			width="96"
			height="96"
			class="mb-1 hidden h-16 w-16 drop-shadow-lg sm:block [@media(max-height:800px)]:h-10 [@media(max-height:800px)]:w-10"
			aria-hidden="true"></canvas>
		<h2 class="text-xl font-extrabold tracking-tight sm:text-3xl [@media(max-height:800px)]:sm:text-2xl">
			{EN.title}
		</h2>
		<p class="mt-1 text-xs text-indigo-200 sm:text-sm [@media(max-height:800px)]:sm:text-xs">
			{EN.chooseHero}
		</p>
	</div>

	<!-- Run summary shown after a game over (hidden otherwise). -->
	<p
		id="run-summary"
		class="mt-4 hidden rounded-xl bg-amber-400/15 px-4 py-1.5 text-sm font-semibold text-amber-200"
	>
	</p>

	<!-- Cards group: generous space above (separates from header). -->
	<div
		id="char-cards"
		class="mt-6 flex flex-wrap items-stretch justify-center gap-3 [@media(max-height:800px)]:mt-4 [@media(max-height:800px)]:gap-2"
	>
		<!-- Cards injected by script (one per CHARACTERS entry). -->
	</div>

	<!-- Start button: clear space from the cards (this was the cramped gap). -->
	<button
		id="start-btn"
		type="button"
		disabled
		class="mt-6 rounded-full bg-amber-400 px-8 py-2 text-base font-extrabold text-stone-900 shadow-lg transition enabled:hover:scale-105 enabled:hover:bg-amber-300 disabled:cursor-not-allowed disabled:opacity-40 sm:text-lg sm:py-2.5 [@media(max-height:800px)]:mt-3 [@media(max-height:800px)]:py-1.5 [@media(max-height:800px)]:text-sm"
	>
		{EN.startButton}
	</button>

	<!-- Instructions group: separated block at the bottom. -->
	<p
		class="mt-6 bg-gradient-to-r from-amber-300 via-pink-300 to-amber-300 bg-clip-text text-base font-extrabold tracking-tight text-transparent sm:text-xl [@media(max-height:800px)]:mt-3 [@media(max-height:800px)]:sm:text-base"
	>
		{EN.instructionsHeadline}
	</p>
	<div
		class="mt-3 w-full max-w-md rounded-2xl bg-indigo-950/40 px-4 py-3 text-left text-xs font-medium text-indigo-100 ring-1 ring-white/10 sm:px-5 sm:py-4 sm:text-sm [@media(max-height:800px)]:mt-2 [@media(max-height:800px)]:py-2 [@media(max-height:800px)]:sm:py-2.5 [@media(max-height:800px)]:sm:text-xs"
	>
		<ul class="space-y-1.5 [@media(max-height:800px)]:space-y-0.5">
			{
				EN.instructions.map((line) => (
					<li class="flex items-start gap-2">
						<span class="w-5 shrink-0 text-center leading-5 [@media(max-height:800px)]:leading-4">
							{line.icon}
						</span>
						<span class="leading-5 [@media(max-height:800px)]:leading-4">
							{line.text}
						</span>
					</li>
				))
			}
		</ul>
		<p
			class="mt-3 border-t border-white/10 pt-3 text-xs text-indigo-300 [@media(max-height:800px)]:mt-1.5 [@media(max-height:800px)]:pt-1.5"
		>
			{EN.controlsHint}
		</p>
	</div>
</div>
