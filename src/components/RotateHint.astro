---
import { EN } from "../game/strings/en";
---

<!-- Rotate-to-landscape hint, shown only on portrait touch devices. -->
<div
	id="rotate-hint"
	class="absolute inset-0 z-40 hidden flex-col items-center justify-center gap-3 bg-stone-950/90 px-6 text-center text-amber-50"
>
	<div class="text-4xl" aria-hidden="true">⟳</div>
	<p class="text-lg font-bold">{EN.rotateHint}</p>
</div>
