---
// Boot skeleton: covers the whole stage immediately on load (so the bare canvas
// never flashes) until the game + previews are ready.
---

<div
	id="boot-skeleton"
	class="absolute inset-0 z-30 flex flex-col items-center justify-center gap-4 bg-gradient-to-b from-indigo-950 to-purple-950"
>
	<div class="h-10 w-64 animate-pulse rounded-lg bg-white/10"></div>
	<div class="h-4 w-40 animate-pulse rounded bg-white/10"></div>
	<div class="mt-2 flex gap-4">
		<div class="h-28 w-20 animate-pulse rounded-2xl bg-white/10 sm:h-44 sm:w-36"></div>
		<div class="h-28 w-20 animate-pulse rounded-2xl bg-white/10 sm:h-44 sm:w-36"></div>
		<div class="h-28 w-20 animate-pulse rounded-2xl bg-white/10 sm:h-44 sm:w-36"></div>
		<div class="h-28 w-20 animate-pulse rounded-2xl bg-white/10 sm:h-44 sm:w-36"></div>
	</div>
	<div class="mt-2 h-11 w-40 animate-pulse rounded-full bg-white/10"></div>
</div>
